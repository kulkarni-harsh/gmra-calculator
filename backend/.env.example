PROJECT_NAME=MERC
VERSION=1.0.0
API_PREFIX=/api/v2
DEBUG=true

# --- Real API keys (required) ---
OPENCAGE_API_KEY=your_opencage_key
CENSUS_API_KEY=your_census_key
MAPBOX_API_KEY=your_mapbox_key
ALPHASOPHIA_API_KEY=your_alphasophia_key

# --- AWS (LocalStack for local dev) ---
# These fake creds satisfy boto3's credential check; LocalStack doesn't validate them.
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Routes ALL boto3 calls to LocalStack instead of real AWS.
# Remove (or set to "") when running against real AWS.
AWS_ENDPOINT_URL=http://localhost:4566

# --- Async job infra ---
DYNAMODB_TABLE_NAME=merc-jobs
SQS_QUEUE_URL=http://localhost:4566/000000000000/merc-jobs

# --- Email (optional in local dev — leave blank to skip sending) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
