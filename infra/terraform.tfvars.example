aws_region  = "us-east-1"
domain_name = "yourdomain.com"

# Route 53 NS records — copy from your hosted zone after first apply or from registrar
ns_records = [
  "ns-xxx.awsdns-xx.org.",
  "ns-xxx.awsdns-xx.co.uk.",
  "ns-xxx.awsdns-xx.com.",
  "ns-xxx.awsdns-xx.net.",
]
census_api_key      = "your-census-key"
mapbox_api_key      = "your-mapbox-key"
alphasophia_api_key = "your-alphasophia-key"
google_api_key      = "your-google-key"
# Resend — API key from resend.com dashboard (starts with re_…)
resend_api_key     = "re_..."
resend_dkim_value  = "p=..."   # from Resend dashboard → Domains → DKIM
resend_mx_value    = "10 feedback-smtp.us-east-1.amazonses.com"
resend_spf_value   = "v=spf1 include:amazonses.com ~all"

# Stripe — from stripe.com dashboard
stripe_secret_key      = "sk_live_..."   # or sk_test_…
stripe_webhook_secret  = "whsec_..."
stripe_publishable_key = "pk_live_..."   # or pk_test_…

# Wix partnership integration
api_key_wix      = "GENERATE_WITH_openssl_rand_base64_36"
api_key_react    = "GENERATE_WITH_openssl_rand_base64_36"
auth_enforced    = false                          # flip to true after Wix smoke test
internal_origins = "https://app.merc.com"         # comma-separated; our own React origins
openapi_public   = true                           # set false in prod
