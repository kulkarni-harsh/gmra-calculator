# ── External API keys (required — app will not start without these) ──────────
CENSUS_API_KEY=your_census_key
MAPBOX_API_KEY=your_mapbox_key
ALPHASOPHIA_API_KEY=your_alphasophia_key

# ── Email (required in prod; leave blank to skip sending in local dev) ────────
RESEND_API_KEY=re_...
# Used to build the status-check link in confirmation emails (e.g. https://yourdomain.com)
FRONTEND_URL=http://localhost:5173

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── AWS region ────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1

# ── Job infrastructure ────────────────────────────────────────────────────────
# SQS_QUEUE_URL is required — no default (URL is environment-specific).
SQS_QUEUE_URL=http://localhost:4566/000000000000/merc-jobs

# ── Optional overrides (defaults shown; only set if you rename the resources) ─
# DYNAMODB_TABLE_NAME=merc-jobs
# S3_BUCKET_NAME=merc-reports

# ── Local dev only — DO NOT set these in production ──────────────────────────
# ECS uses IAM task roles; boto3 does not need explicit credentials there.
# AWS_ENDPOINT_URL routes all boto3 calls to LocalStack — must not exist in prod.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
